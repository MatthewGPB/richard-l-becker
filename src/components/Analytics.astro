---
// ============================================================
// ANALYTICS — all trackers live here and read their IDs from
// src/config.ts. A tracker only renders if its ID is non-empty,
// so nothing loads (and nothing slows the site) until you paste
// real IDs into the config.
//
// Included placeholders:
//   1. Google Tag Manager (GTM_ID)
//   2. Google Analytics 4 (GA4_ID)
//   3. Meta Pixel — Facebook/Instagram ads (META_PIXEL_ID)
//   4. X / Twitter Pixel (X_PIXEL_ID)
//   5. TikTok Pixel (TIKTOK_PIXEL_ID)
//   6. Microsoft Clarity (CLARITY_ID)
//   7. Pinterest Tag (PINTEREST_TAG_ID)
// ============================================================
import { ANALYTICS } from '../config';

const { GTM_ID, GA4_ID, META_PIXEL_ID, X_PIXEL_ID, TIKTOK_PIXEL_ID, CLARITY_ID, PINTEREST_TAG_ID } = ANALYTICS;
